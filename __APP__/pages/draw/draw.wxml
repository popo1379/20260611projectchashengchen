<view class="page">
    <view class="header">
        <text class="scene-title">{{sceneName}}</text>
        <text class="scene-subtitle">心诚则灵，每日一签</text>
    </view>

    <!-- 已抽签结果展示 -->
    <view class="result-card" wx:if="{{hasDrawn}}">
        <view class="result-header" style="background: {{qian.levelBg}}; color: {{qian.levelColor}};">
            <text class="level-text">{{qian.level}}</text>
        </view>
        <view class="result-body">
            <text class="qian-title">{{qian.title}}</text>
            <view class="qian-poem">
                <text class="poem-text">{{qian.poem}}</text>
            </view>
            <view class="result-tip">
                <text class="tip-text">心诚则灵，请明日再来一签</text>
            </view>
            <button class="detail-btn" bindtap="goToDetail" style="background-color: #242122; color: #f3d49b;">
                查看完整签文释义
            </button>
        </view>
    </view>

    <!-- 抽签动画区域 -->
    <view class="draw-area" wx:if="{{!hasDrawn}}">
        <!-- 签筒 -->
        <view class="qian-tube" animation="{{tubeAnimation}}">
            <text class="tube-text">签</text>
        </view>
        
        <!-- 抽签按钮 -->
        <button class="draw-btn" bindtap="doDraw" wx:if="{{!isDrawing}}" style="background-color: #242122; color: #f3d49b;">
            点击抽取今日签
        </button>
        
        <!-- 抽签中提示 -->
        <view class="drawing-tip" wx:if="{{isDrawing}}">
            <text class="tip-text">正在抽取...</text>
        </view>
    </view>

    <!-- 抽签结果预览 -->
    <view class="result-preview" wx:if="{{showResult}}">
        <view class="preview-card" style="border: 4rpx solid {{qian.levelColor}}; background: {{qian.levelBg}};">
            <view class="preview-level">
                <text class="level" style="color: {{qian.levelColor}};">{{qian.level}}</text>
            </view>
            <view class="preview-title">
                <text class="title">{{qian.title}}</text>
            </view>
            <view class="preview-poem">
                <text class="poem">{{qian.poem}}</text>
            </view>
            <button class="detail-btn" bindtap="goToDetail" style="background-color: #242122; color: #f3d49b;">
                查看完整签文释义
            </button>
        </view>
    </view>
</view>
