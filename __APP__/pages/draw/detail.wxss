.page {
    min-height: 100vh;
    background: linear-gradient(135deg, #faf9f6 0%, #fffaf6 50%, #f8f7f4 100%);
}

.qian-header {
    padding: 60rpx 40rpx 80rpx;
    text-align: center;
    position: relative;
}

.level-badge {
    display: inline-block;
    padding: 15rpx 40rpx;
    border-radius: 50rpx;
    margin-bottom: 20rpx;
}

.level-badge .level-text {
    font-size: 36rpx;
    font-weight: bold;
}

.scene-tag {
    display: inline-block;
    padding: 8rpx 24rpx;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 20rpx;
}

.scene-tag .scene-text {
    font-size: 24rpx;
    color: #666;
}

.qian-body {
    margin-top: -40rpx;
    padding: 0 30rpx 60rpx;
}

.qian-title-section {
    background: #fff;
    border-radius: 20rpx;
    padding: 50rpx 40rpx;
    text-align: center;
    margin-bottom: 30rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
}

.qian-title {
    font-size: 48rpx;
    font-weight: bold;
    color: #242122;
    letter-spacing: 8rpx;
}

.qian-poem-section {
    margin-bottom: 30rpx;
}

.poem-container {
    position: relative;
    background: #fff;
    border-radius: 20rpx;
    padding: 50rpx 40rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
    overflow: hidden;
}

.poem-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #faf9f6;
    opacity: 0.3;
}

.poem-content {
    position: relative;
    z-index: 1;
}

.poem-text {
    display: block;
    font-size: 32rpx;
    color: #333;
    line-height: 2.2;
    text-align: center;
    font-family: 'KaiTi', '楷体', 'STKaiti', serif;
    letter-spacing: 4rpx;
}

.qian-interpretation-section {
    background: #fff;
    border-radius: 20rpx;
    padding: 40rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
}

.section-title {
    text-align: center;
    margin-bottom: 30rpx;
    position: relative;
}

.title-text {
    font-size: 32rpx;
    font-weight: bold;
    color: #242122;
}

.interpretation-content {
    padding: 20rpx 0;
}

.interpretation-text {
    font-size: 28rpx;
    color: #555;
    line-height: 2;
    text-align: justify;
}

.action-section {
    padding: 30rpx 0;
}

.action-btn {
    width: 100%;
    height: 90rpx;
    line-height: 90rpx;
    border-radius: 45rpx;
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
}

.action-btn:last-child {
    margin-bottom: 0;
}

.action-btn.primary {
    background-color: #242122;
    color: #f3d49b;
}

.action-btn.secondary {
    background-color: transparent;
    border: 2rpx solid #242122;
    color: #242122;
}

.action-btn.primary::after,
.action-btn.secondary::after {
    border: none;
}
