.page {
    min-height: 100vh;
    background: linear-gradient(135deg, #faf9f6 0%, #fffaf6 50%, #f8f7f4 100%);
    padding: 20rpx;
}

.header {
    text-align: center;
    padding: 40rpx 0;
}

.scene-title {
    display: block;
    font-size: 44rpx;
    font-weight: bold;
    color: #242122;
    margin-bottom: 15rpx;
}

.scene-subtitle {
    display: block;
    font-size: 26rpx;
    color: #999;
}

.result-card {
    margin: 30rpx 20rpx;
    background: #fff;
    border-radius: 24rpx;
    overflow: hidden;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}

.result-header {
    padding: 40rpx 30rpx;
    text-align: center;
}

.level-text {
    font-size: 48rpx;
    font-weight: bold;
}

.result-body {
    padding: 40rpx 30rpx;
    text-align: center;
}

.qian-title {
    display: block;
    font-size: 36rpx;
    font-weight: bold;
    color: #242122;
    margin-bottom: 30rpx;
}

.qian-poem {
    margin: 30rpx 0;
}

.poem-text {
    font-size: 28rpx;
    color: #555;
    line-height: 1.8;
    font-family: 'KaiTi', '楷体', serif;
}

.result-tip {
    margin: 30rpx 0;
    padding: 20rpx;
    background: #fff8e6;
    border-radius: 12rpx;
}

.tip-text {
    font-size: 26rpx;
    color: #b8860b;
}

.detail-btn {
    width: 80%;
    height: 90rpx;
    line-height: 90rpx;
    border-radius: 45rpx;
    font-size: 32rpx;
    font-weight: bold;
    margin: 30rpx auto;
}

.draw-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80rpx 0;
}

.qian-tube {
    width: 200rpx;
    height: 200rpx;
    background: linear-gradient(135deg, #8b4513 0%, #654321 50%, #8b4513 100%);
    border-radius: 20rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 60rpx;
    box-shadow: 0 10rpx 30rpx rgba(139, 69, 19, 0.3);
    position: relative;
}

.qian-tube::before {
    content: '';
    position: absolute;
    top: -15rpx;
    left: 50%;
    transform: translateX(-50%);
    width: 180rpx;
    height: 30rpx;
    background: linear-gradient(135deg, #654321 0%, #8b4513 100%);
    border-radius: 10rpx 10rpx 0 0;
}

.tube-text {
    font-size: 60rpx;
    color: #f3d49b;
    font-weight: bold;
}

.draw-btn {
    width: 500rpx;
    height: 100rpx;
    line-height: 100rpx;
    border-radius: 50rpx;
    font-size: 36rpx;
    font-weight: bold;
}

.drawing-tip {
    text-align: center;
    padding: 20rpx;
}

.drawing-tip .tip-text {
    font-size: 32rpx;
    color: #666;
}

.result-preview {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
}

.preview-card {
    width: 90%;
    background: #fff;
    border-radius: 24rpx;
    padding: 50rpx 40rpx;
    text-align: center;
    box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.preview-level {
    margin-bottom: 30rpx;
}

.preview-level .level {
    font-size: 52rpx;
    font-weight: bold;
}

.preview-title {
    margin-bottom: 30rpx;
}

.preview-title .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #242122;
}

.preview-poem {
    margin: 30rpx 0;
    padding: 30rpx;
    background: #faf9f6;
    border-radius: 16rpx;
}

.preview-poem .poem {
    font-size: 28rpx;
    color: #555;
    line-height: 1.8;
    font-family: 'KaiTi', '楷体', serif;
}

.preview-card .detail-btn {
    width: 90%;
    margin-top: 40rpx;
}
