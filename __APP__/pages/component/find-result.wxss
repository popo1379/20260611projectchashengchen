.result-box {
    background: #fff;
    border-radius: 20rpx;
    margin: 20rpx auto;
    padding: 30rpx;
    width: 90%;
}

.row {
    display: flex;
    align-items: center;
    padding: 16rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
    font-size: 28rpx;
}

.row:last-child {
    border-bottom: none;
}

.label {
    color: #666;
    min-width: 160rpx;
    font-size: 26rpx;
}

.mr-20 {
    color: #666;
    margin-right: 20rpx;
}

.values {
    color: #333;
    flex: 1;
}

.values.bazi {
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
}

.values.bazi .col {
    padding: 8rpx 16rpx;
    border-radius: 8rpx;
    font-size: 28rpx;
    font-weight: bold;
}

/* 四柱网格样式 */
.bazi-grid {
    background: linear-gradient(135deg, #fef9f3 0%, #fff8f0 100%);
    border-radius: 16rpx;
    padding: 20rpx;
    margin: 20rpx 0;
    border: 2rpx solid #f0e6d8;
}

.bazi-header-row {
    display: flex;
    justify-content: space-around;
    margin-bottom: 16rpx;
}

.bazi-header-cell {
    flex: 1;
    text-align: center;
    font-size: 24rpx;
    color: #999;
    font-weight: 500;
}

.bazi-row {
    display: flex;
    justify-content: space-around;
    margin-bottom: 8rpx;
}

.bazi-cell {
    flex: 1;
    text-align: center;
    padding: 16rpx 8rpx;
}

.bazi-ganzhi {
    font-size: 36rpx;
    font-weight: bold;
    padding: 12rpx 20rpx;
    border-radius: 12rpx;
    display: inline-block;
}

.bazi-cell-sub {
    flex: 1;
    text-align: center;
    padding: 8rpx 0;
}

.bazi-wuxing {
    font-size: 22rpx;
    padding: 6rpx 12rpx;
    border-radius: 8rpx;
    display: inline-block;
    margin: 2rpx 0;
}

.bazi-wuxing-rizhu {
    font-size: 22rpx;
    padding: 6rpx 12rpx;
    border-radius: 8rpx;
    display: inline-block;
    margin: 2rpx 0;
    background: transparent;
    color: #333;
}

.bazi-label-row {
    display: flex;
    justify-content: center;
    padding: 4rpx 0;
    margin: 8rpx 0 4rpx;
}

.bazi-label {
    font-size: 22rpx;
    color: #666;
    background: #f5f0e8;
    padding: 4rpx 24rpx;
    border-radius: 20rpx;
    font-weight: 500;
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin: 30rpx 0 20rpx;
    padding-bottom: 16rpx;
    border-bottom: 2rpx solid #f7c261;
}

.nayin-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
    margin-top: 20rpx;
}

.nayin-item {
    background: #f9f9f9;
    border-radius: 12rpx;
    padding: 20rpx;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10rpx;
}

.nayin-item text:first-child {
    color: #999;
    font-size: 24rpx;
}

.nayin-value {
    color: #f7c261;
    font-size: 28rpx;
    font-weight: bold;
}

.tenstar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16rpx;
    margin-top: 20rpx;
}

.tenstar-item {
    background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
    border-radius: 12rpx;
    padding: 20rpx 10rpx;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10rpx;
}

.tenstar-item text:first-child {
    color: #666;
    font-size: 22rpx;
}

.tenstar-value {
    color: #e65100;
    font-size: 26rpx;
    font-weight: bold;
}

.xiyong-box {
    background: #f9f9f9;
    border-radius: 12rpx;
    padding: 24rpx;
    margin-top: 20rpx;
}

.xiyong-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12rpx 0;
    border-bottom: 1rpx solid #eee;
}

.xiyong-row:last-child {
    border-bottom: none;
}

.xiyong-row .label {
    color: #666;
    font-size: 26rpx;
}

.xiyong-row .value {
    color: #333;
    font-size: 26rpx;
    font-weight: 500;
}

.xi-color {
    color: #4CAF50;
    font-weight: bold;
    margin-right: 20rpx;
}

.yong-color {
    color: #2196F3;
    font-weight: bold;
}

.dayun-box {
    margin-top: 20rpx;
}

.dayun-start {
    color: #666;
    font-size: 26rpx;
    margin-bottom: 16rpx;
}

.dayun-scroll {
    width: 100%;
}

.dayun-list {
    display: flex;
    gap: 20rpx;
    padding: 10rpx 0;
}

.dayun-item {
    flex-shrink: 0;
    background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
    border: 2rpx solid #f7c261;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    min-width: 140rpx;
}

.dayun-age {
    color: #f7c261;
    font-size: 28rpx;
    font-weight: bold;
}

.dayun-ganzhi {
    color: #333;
    font-size: 30rpx;
    font-weight: bold;
}

.dayun-year {
    color: #999;
    font-size: 22rpx;
}

.ui-jin {
    background: #50616d;
    color: #Cfb53b;
}

.ui-mu {
    background: #e8f5e9;
    color: #4CAF50;
}

.ui-shui {
    background: #e3f2fd;
    color: #2196F3;
}

.ui-huo {
    background: #ffebee;
    color: #f44336;
}

.ui-tu {
    background: #fff8e1;
    color: #FFC107;
}

.interpret-btn-box {
    margin-top: 30rpx;
    padding: 10rpx 0;
}

.interpret-btn {
    background: linear-gradient(135deg, #f7c261 0%, #f5a623 100%);
    color: #fff;
    font-size: 28rpx;
    font-weight: bold;
    text-align: center;
    padding: 20rpx 40rpx;
    border-radius: 50rpx;
    box-shadow: 0 4rpx 12rpx rgba(247, 194, 97, 0.4);
}

.interpret-modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
}

.interpret-modal {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    border-radius: 30rpx 30rpx 0 0;
    z-index: 1000;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
}

.interpret-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #eee;
    background: #fff;
}

.interpret-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}

.interpret-close {
    font-size: 50rpx;
    color: #999;
    line-height: 1;
    padding: 0 10rpx;
}

.interpret-content {
    flex: 1;
    overflow-y: auto;
    padding: 30rpx;
}

.interpret-section {
    margin-bottom: 40rpx;
}

.interpret-section-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #f7c261;
    margin-bottom: 20rpx;
    padding-left: 16rpx;
    border-left: 4rpx solid #f7c261;
}

.interpret-summary {
    background: #fff8e1;
    border-radius: 12rpx;
    padding: 20rpx;
    color: #333;
    font-size: 26rpx;
    line-height: 1.6;
    margin-bottom: 16rpx;
}

.interpret-keywords {
    color: #999;
    font-size: 24rpx;
    margin-bottom: 20rpx;
}

.interpret-detail {
    margin-bottom: 20rpx;
}

.interpret-detail-title {
    color: #666;
    font-size: 24rpx;
    margin-bottom: 8rpx;
}

.interpret-detail-text {
    color: #333;
    font-size: 26rpx;
    line-height: 1.6;
    padding-left: 12rpx;
    border-left: 2rpx solid #f7c261;
}
