.page {
    min-height: 100vh;
    background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    padding-bottom: 120rpx;
}

.header {
    padding: 40rpx 30rpx 30rpx;
    text-align: center;
}

.title {
    display: block;
    font-size: 40rpx;
    font-weight: bold;
    color: #f4d35e;
    margin-bottom: 10rpx;
}

.subtitle {
    display: block;
    font-size: 24rpx;
    color: #c9c9d6;
}

/* 八字信息卡片 */
.bazi-card {
    margin: 20rpx 30rpx;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 16rpx;
    padding: 24rpx;
}

.bazi-row {
    display: flex;
    justify-content: space-around;
}

.bazi-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.bazi-label {
    font-size: 22rpx;
    color: #7d7d8a;
    margin-bottom: 8rpx;
}

.bazi-value {
    font-size: 32rpx;
    color: #ffffff;
    font-weight: bold;
}

.bazi-value.highlight {
    color: #f4d35e;
}

.bazi-summary {
    margin-top: 16rpx;
    text-align: center;
    font-size: 24rpx;
    color: #c9c9d6;
}

/* 加载状态 */
.loading-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 30rpx;
}

.loading-icon {
    width: 120rpx;
    height: 120rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 30rpx;
}

.loading-text {
    font-size: 80rpx;
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.95); }
}

.loading-tip {
    font-size: 28rpx;
    color: #f4d35e;
    margin-bottom: 16rpx;
}

.loading-subtip {
    font-size: 24rpx;
    color: #7d7d8a;
}

/* 错误状态 */
.error-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 30rpx;
}

.error-icon {
    font-size: 60rpx;
    margin-bottom: 20rpx;
}

.error-text {
    font-size: 26rpx;
    color: #ee964b;
    margin-bottom: 30rpx;
    text-align: center;
}

.retry-btn {
    width: 200rpx;
    height: 72rpx;
    line-height: 72rpx;
    background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%);
    color: #1a1a2e;
    font-size: 28rpx;
    font-weight: bold;
    border-radius: 36rpx;
    border: none;
}

/* 标签栏 */
.tab-bar {
    display: flex;
    justify-content: space-around;
    margin: 20rpx 30rpx;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 12rpx;
    padding: 16rpx;
}

.tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12rpx 20rpx;
    border-radius: 8rpx;
}

.tab-item.active {
    background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%);
}

.tab-icon {
    font-size: 32rpx;
    margin-bottom: 6rpx;
}

.tab-name {
    font-size: 22rpx;
    color: #c9c9d6;
}

.tab-item.active .tab-name {
    color: #1a1a2e;
    font-weight: bold;
}

/* 内容区域 */
.content-area {
    margin: 20rpx 30rpx;
}

.content-card {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 16rpx;
    padding: 30rpx;
}

.content-text {
    font-size: 28rpx;
    color: #d9d9e5;
    line-height: 1.9;
    letter-spacing: 0.5rpx;
}

/* 提示信息 */
.tip-section {
    margin: 30rpx;
    text-align: center;
}

.tip-text {
    font-size: 22rpx;
    color: #7d7d8a;
}

/* 底部按钮 */
.bottom-actions {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20rpx 30rpx;
    background: rgba(26, 26, 46, 0.95);
    display: flex;
    gap: 20rpx;
}

.action-btn {
    flex: 1;
    height: 88rpx;
    line-height: 88rpx;
    font-size: 28rpx;
    border-radius: 44rpx;
    border: none;
}

.action-btn.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
}

.action-btn.primary {
    background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%);
    color: #1a1a2e;
    font-weight: bold;
}