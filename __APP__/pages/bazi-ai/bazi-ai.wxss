.page {
    min-height: 100vh;
    background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    display: flex;
    flex-direction: column;
    padding-top: 0;
}

/* 八字信息卡片 */
.bazi-card {
    margin: 20rpx 30rpx;
    padding: 24rpx;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
    border-radius: 20rpx;
    border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.bazi-pillars {
    display: flex;
    justify-content: space-around;
    margin-bottom: 16rpx;
}

.pillar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.pillar-label {
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 8rpx;
}

.pillar-value {
    font-size: 32rpx;
    font-weight: bold;
    color: #f4d35e;
    letter-spacing: 2rpx;
}

.bazi-info {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 12rpx;
    border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-item {
    font-size: 24rpx;
    color: #c9c9d6;
}

.info-divider {
    font-size: 24rpx;
    color: rgba(255, 255, 255, 0.3);
    margin: 0 16rpx;
}

/* 对话区域 */
.chat-area {
    flex: 1;
    padding: 20rpx 30rpx;
    overflow: hidden;
}

/* 推荐问题区域 */
.suggestions-section {
    padding: 30rpx 0;
}

.suggestions-header {
    display: flex;
    align-items: flex-start;
    margin-bottom: 24rpx;
}

.suggestions-header .ai-avatar {
    font-size: 48rpx;
    margin-right: 16rpx;
}

.ai-intro {
    font-size: 28rpx;
    color: #d9d9e5;
    line-height: 1.6;
    flex: 1;
}

.suggestions-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.suggestion-item {
    background: rgba(255, 255, 255, 0.08);
    border: 1rpx solid rgba(255, 255, 255, 0.15);
    border-radius: 24rpx;
    padding: 24rpx 30rpx;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
}

.suggestion-item:active {
    background: rgba(255, 255, 255, 0.15);
    transform: scale(0.98);
}

/* 主要问题样式（完整命理分析报告） */
.suggestion-item.main-question {
    background: linear-gradient(135deg, rgba(244, 211, 94, 0.2) 0%, rgba(238, 150, 75, 0.2) 100%);
    border: 1rpx solid rgba(244, 211, 94, 0.4);
}

.suggestion-item.main-question .suggestion-icon {
    font-size: 40rpx;
}

.suggestion-item.main-question .suggestion-text {
    color: #f4d35e;
    font-weight: 500;
}

.suggestion-icon {
    font-size: 36rpx;
    margin-right: 20rpx;
}

.suggestion-text {
    font-size: 30rpx;
    color: #ffffff;
}

/* 消息列表 */
.messages-list {
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

/* 消息项 */
.message-item {
    display: flex;
    align-items: flex-start;
    max-width: 85%;
}

.message-item.user {
    align-self: flex-end;
    flex-direction: row-reverse;
}

.message-item.ai {
    align-self: flex-start;
}

/* 消息气泡 */
.message-content {
    padding: 20rpx 28rpx;
    border-radius: 24rpx;
    position: relative;
}

.user .message-content {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #ffffff;
    border-bottom-right-radius: 8rpx;
    margin-right: 16rpx;
}

.ai-content {
    background: rgba(255, 255, 255, 0.12);
    color: #d9d9e5;
    border-bottom-left-radius: 8rpx;
    margin-left: 16rpx;
}

.message-text {
    font-size: 28rpx;
    line-height: 1.7;
    word-break: break-all;
}

/* 头像 */
.message-avatar {
    width: 72rpx;
    height: 72rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    flex-shrink: 0;
}

.message-avatar text {
    font-size: 40rpx;
}

/* 加载指示器 */
.loading-indicator {
    display: flex;
    align-items: center;
    padding: 20rpx 0;
    margin-left: 88rpx;
}

.loading-dots {
    font-size: 26rpx;
    color: #7d7d8a;
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

/* 内联推荐问题 */
.inline-suggestions {
    margin-top: 30rpx;
    padding-top: 30rpx;
    border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.suggestions-label {
    font-size: 24rpx;
    color: #7d7d8a;
    margin-bottom: 16rpx;
}

.inline-suggestions-scroll {
    width: 100%;
    white-space: nowrap;
}

.inline-suggestions-list {
    display: inline-flex;
    gap: 12rpx;
    padding-right: 30rpx;
}

.suggestion-tag {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 20rpx;
    padding: 14rpx 20rpx;
    flex-shrink: 0;
}

.suggestion-tag:active {
    background: rgba(255, 255, 255, 0.2);
}

.tag-icon {
    font-size: 24rpx;
    margin-right: 10rpx;
}

.tag-text {
    font-size: 24rpx;
    color: #ffffff;
    white-space: nowrap;
}

/* 底部占位 */
.bottom-placeholder {
    height: 140rpx;
}

/* 错误提示 */
.error-section {
    padding: 30rpx;
    text-align: center;
}

.error-text {
    font-size: 26rpx;
    color: #ee964b;
}

/* 输入区域 */
.input-area {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20rpx 30rpx;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
    background: rgba(26, 26, 46, 0.95);
    display: flex;
    align-items: center;
    gap: 20rpx;
    border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.input-field {
    flex: 1;
    height: 80rpx;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 40rpx;
    padding: 0 30rpx;
    font-size: 28rpx;
    color: #ffffff;
}

.input-field::placeholder {
    color: #7d7d8a;
}

.send-btn {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.send-btn.active {
    background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%);
}

.send-icon {
    font-size: 32rpx;
    color: #7d7d8a;
}

.send-btn.active .send-icon {
    color: #1a1a2e;
}