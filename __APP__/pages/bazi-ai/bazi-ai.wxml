<view class="page">
    <!-- 八字信息卡片 -->
    <view class="bazi-card" wx:if="{{baziData}}">
        <view class="bazi-pillars">
            <view class="pillar-item">
                <text class="pillar-label">年柱</text>
                <text class="pillar-value">{{baziData.yearPillar}}</text>
            </view>
            <view class="pillar-item">
                <text class="pillar-label">月柱</text>
                <text class="pillar-value">{{baziData.monthPillar}}</text>
            </view>
            <view class="pillar-item">
                <text class="pillar-label">日柱</text>
                <text class="pillar-value">{{baziData.dayPillar}}</text>
            </view>
            <view class="pillar-item">
                <text class="pillar-label">时柱</text>
                <text class="pillar-value">{{baziData.hourPillar}}</text>
            </view>
        </view>
        <view class="bazi-info">
            <text class="info-item">日主 {{baziData.dayMaster}}</text>
            <text class="info-divider">|</text>
            <text class="info-item">{{baziData.strengthStatus}}</text>
            <text class="info-divider">|</text>
            <text class="info-item">喜{{baziData.xiElement}} 用{{baziData.yongElement}}</text>
        </view>
    </view>

    <!-- 错误提示 -->
    <view class="error-section" wx:if="{{error}}">
        <text class="error-text">{{error}}</text>
    </view>

    <!-- 对话区域 -->
    <scroll-view 
        class="chat-area" 
        scroll-y 
        scroll-with-animation 
        scroll-top="{{scrollTop}}">
        
        <!-- 推荐问题（初始状态） -->
        <view class="suggestions-section" wx:if="{{suggestions.length > 0 && messages.length === 0}}">
            <view class="suggestions-header">
                <text class="ai-avatar">🤖</text>
                <text class="ai-intro">根据您的八字，为您推荐以下问题：</text>
            </view>
            <view class="suggestions-list">
                <block wx:for="{{suggestions}}" wx:key="id">
                    <view class="suggestion-item {{item.isMain ? 'main-question' : ''}}" bindtap="clickSuggestion" data-question="{{item}}">
                        <text class="suggestion-icon">{{item.icon}}</text>
                        <text class="suggestion-text">{{item.text}}</text>
                    </view>
                </block>
            </view>
        </view>

        <!-- 消息列表 -->
        <view class="messages-list">
            <block wx:for="{{messages}}" wx:key="index">
                <!-- 用户消息 -->
                <view class="message-item user" id="msg-{{index}}" wx:if="{{item.role === 'user'}}">
                    <view class="message-content">
                        <text class="message-text">{{item.content}}</text>
                    </view>
                    <view class="message-avatar user-avatar">
                        <text>👤</text>
                    </view>
                </view>

                <!-- AI回复 -->
                <view class="message-item ai" id="msg-{{index}}" wx:if="{{item.role === 'assistant'}}">
                    <view class="message-avatar ai-avatar">
                        <text>🤖</text>
                    </view>
                    <view class="message-content ai-content">
                        <text class="message-text">{{item.content}}</text>
                    </view>
                </view>
            </block>

            <!-- 加载中 -->
            <view class="loading-indicator" wx:if="{{isLoading}}">
                <text class="loading-dots">🤖 正在思考...</text>
            </view>

            <!-- 对话中的推荐问题 -->
            <view class="inline-suggestions" wx:if="{{suggestions.length > 0 && messages.length > 0 && !isLoading}}">
                <view class="suggestions-label">
                    <text>💡 您还可以问：</text>
                </view>
                <scroll-view class="inline-suggestions-scroll" scroll-x>
                    <view class="inline-suggestions-list">
                        <block wx:for="{{suggestions}}" wx:key="id">
                            <view class="suggestion-tag" bindtap="clickSuggestion" data-question="{{item}}">
                                <text class="tag-icon">{{item.icon}}</text>
                                <text class="tag-text">{{item.text}}</text>
                            </view>
                        </block>
                    </view>
                </scroll-view>
            </view>
        </view>

        <!-- 底部占位 -->
        <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="input-area">
        <input 
            class="input-field" 
            type="text" 
            placeholder="输入你想问的问题..."
            value="{{inputText}}"
            bindinput="onInputChange"
            bindconfirm="sendMessage"
            confirm-type="send"
        />
        <view class="send-btn {{inputText.trim() ? 'active' : ''}}" bindtap="sendMessage">
            <text class="send-icon">➤</text>
        </view>
    </view>
</view>