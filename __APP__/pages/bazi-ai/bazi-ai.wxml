<view class="page">
    <!-- 顶部导航 -->
    <view class="header">
        <view class="header-left" bindtap="goBack">
            <text class="back-icon">←</text>
        </view>
        <view class="header-title">
            <text class="title">AI 命理问答</text>
        </view>
        <view class="header-right" bindtap="clearChat">
            <text class="clear-btn" wx:if="{{messages.length > 0}}">清空</text>
        </view>
    </view>

    <!-- 八字信息条 -->
    <view class="bazi-bar" wx:if="{{baziData}}">
        <text class="bazi-text">{{baziData.yearPillar}} {{baziData.monthPillar}} {{baziData.dayPillar}} {{baziData.hourPillar}}</text>
        <text class="bazi-desc">日主{{baziData.dayMaster}}{{baziData.strengthStatus}}</text>
    </view>

    <!-- 错误提示 -->
    <view class="error-section" wx:if="{{error}}">
        <text class="error-text">{{error}}</text>
    </view>

    <!-- 对话区域 -->
    <scroll-view 
        class="chat-area" 
        scroll-y 
        scroll-with-animation 
        scroll-top="{{scrollTop}}"
        bindscroll="onScroll">
        
        <!-- 推荐问题（初始状态） -->
        <view class="suggestions-section" wx:if="{{suggestions.length > 0 && messages.length === 0}}">
            <view class="suggestions-header">
                <text class="ai-avatar">🤖</text>
                <text class="ai-intro">根据您的八字，为您推荐以下问题：</text>
            </view>
            <view class="suggestions-list">
                <block wx:for="{{suggestions}}" wx:key="text">
                    <view class="suggestion-item" bindtap="clickSuggestion" data-question="{{item}}">
                        <text class="suggestion-icon">{{item.icon}}</text>
                        <text class="suggestion-text">{{item.text}}</text>
                    </view>
                </block>
            </view>
        </view>

        <!-- 消息列表 -->
        <view class="messages-list">
            <block wx:for="{{messages}}" wx:key="index">
                <!-- 用户消息 -->
                <view class="message-item user" id="msg-{{index}}">
                    <view class="message-content">
                        <text class="message-text">{{item.content}}</text>
                    </view>
                    <view class="message-avatar user-avatar">
                        <text>👤</text>
                    </view>
                </view>

                <!-- AI回复 -->
                <view class="message-item ai" id="msg-{{index + 1}}" wx:if="{{item.role === 'assistant'}}">
                    <view class="message-avatar ai-avatar">
                        <text>🤖</text>
                    </view>
                    <view class="message-content ai-content">
                        <text class="message-text">{{item.content}}</text>
                    </view>
                </view>
            </block>

            <!-- 加载中 -->
            <view class="loading-indicator" wx:if="{{isLoading}}">
                <text class="loading-dots">🤖 正在思考</text>
            </view>

            <!-- 对话中的推荐问题 -->
            <view class="inline-suggestions" wx:if="{{suggestions.length > 0 && messages.length > 0 && !isLoading}}">
                <view class="suggestions-label">
                    <text>💡 您还可以问：</text>
                </view>
                <block wx:for="{{suggestions}}" wx:key="text">
                    <view class="suggestion-item small" bindtap="clickSuggestion" data-question="{{item}}">
                        <text class="suggestion-icon">{{item.icon}}</text>
                        <text class="suggestion-text">{{item.text}}</text>
                    </view>
                </block>
            </view>
        </view>

        <!-- 底部占位 -->
        <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="input-area">
        <input 
            class="input-field" 
            type="text" 
            placeholder="输入你想问的问题..."
            value="{{inputText}}"
            bindinput="onInputChange"
            bindconfirm="sendMessage"
            confirm-type="send"
        />
        <view class="send-btn {{inputText.trim() ? 'active' : ''}}" bindtap="sendMessage">
            <text class="send-icon">➤</text>
        </view>
    </view>
</view>
