.page.data-v-47582f5c {
    background-color: #f8f7f4;
    background-size: 100% 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: 1rpx;
}

.uv-nav-slot.data-v-47582f5c {
    border-radius: 10rpx;
    color: #242122;
    font-weight: 600;
    height: 65rpx;
    line-height: 65rpx;
    position: relative;
    top: -6rpx;
}

.main.data-v-47582f5c {
    backdrop-filter: 20rpx;
    background-color: #fffaf6;
    background-color: #fff;
    background-size: 100% 100%;
    border-radius: 20rpx;
    flex: 1;
    margin: 0rpx auto 0;
    overflow: hidden;
    padding-bottom: 60rpx;
    padding-top: 1rpx;
    position: relative;
    width: 95%;
}

.main .title.data-v-47582f5c {
    color: #242122;
    font-size: 36rpx;
    font-weight: 900;
    margin: 52rpx auto 0;
    padding-bottom: 20rpx;
    text-align: center;
    width: 500rpx;
}

.main input.data-v-47582f5c {
    background: #f5f5f5;
    border-radius: 20rpx;
    color: #242122;
    font-size: 32rpx;
    height: 92rpx;
    margin: 40rpx auto 0;
    text-align: center;
    width: 606rpx;
}

.main .placeholder.data-v-47582f5c {
    color: #cacaca;
    font-size: 32rpx;
}

.main .button.data-v-47582f5c {
    background-color: #242122;
    background-size: 100% 100%;
    border-radius: 50rpx;
    color: #f3d49b;
    font-family: SourceHanSerifCN-Heavy-title;
    font-size: 36rpx;
    font-weight: 700;
    height: 95rpx;
    line-height: 97rpx;
    margin: 40rpx auto 0;
    text-align: center;
    width: 606rpx;
}

/* 每日抽签卡片样式 */
.draw-section.data-v-47582f5c {
    margin-top: 40rpx;
    padding: 0 30rpx;
}

.draw-card.data-v-47582f5c {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.5) 0%, rgba(118, 75, 162, 0.5) 50%, rgba(240, 147, 251, 0.5) 100%);
    border-radius: 16rpx;
    padding: 30rpx;
}

.draw-header.data-v-47582f5c {
    display: flex;
    align-items: center;
    margin-bottom: 24rpx;
}

.draw-icon-large.data-v-47582f5c {
    width: 56rpx;
    height: 56rpx;
    border-radius: 28rpx;
    background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
    color: #fff;
    font-size: 26rpx;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 16rpx;
    flex-shrink: 0;
}

.draw-title.data-v-47582f5c {
    font-size: 32rpx;
    color: #ffffff;
    font-weight: bold;
    text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.draw-grid.data-v-47582f5c {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 16rpx;
}

.draw-grid-item.data-v-47582f5c {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 12rpx;
    padding: 24rpx 12rpx;
}

.draw-grid-item.data-v-47582f5c:active {
    background: rgba(255, 255, 255, 0.2);
}

.draw-grid-icon.data-v-47582f5c {
    font-size: 36rpx;
    margin-bottom: 10rpx;
}

.draw-grid-name.data-v-47582f5c {
    font-size: 22rpx;
    color: #ffffff;
    font-weight: 500;
    text-align: center;
    text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
}

/* 更多功能分割线 */
.more-divider.data-v-47582f5c {
    display: flex;
    align-items: center;
    margin: 50rpx 30rpx 10rpx;
}

.divider-line.data-v-47582f5c {
    flex: 1;
    height: 1rpx;
    background: rgba(0, 0, 0, 0.1);
}

.divider-text.data-v-47582f5c {
    font-size: 24rpx;
    color: #999;
    margin: 0 24rpx;
}

/* 本命星盘入口卡片 */
.astrology-section.data-v-47582f5c {
    margin-top: 20rpx;
    padding: 0 30rpx;
}

.astrology-card.data-v-47582f5c {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, rgba(42, 42, 74, 0.5) 0%, rgba(61, 42, 74, 0.5) 100%);
    border-radius: 16rpx;
    padding: 40rpx 30rpx;
}

.astrology-card.data-v-47582f5c:active {
    opacity: 0.85;
}

.astrology-icon.data-v-47582f5c {
    width: 80rpx;
    height: 80rpx;
    border-radius: 40rpx;
    background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%);
    color: #1a1a2e;
    font-size: 44rpx;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 24rpx;
    flex-shrink: 0;
}

.astrology-content.data-v-47582f5c {
    flex: 1;
}

.astrology-title.data-v-47582f5c {
    font-size: 34rpx;
    color: #f4d35e;
    font-weight: bold;
    margin-bottom: 8rpx;
}

.astrology-subtitle.data-v-47582f5c {
    font-size: 24rpx;
    color: #c9c9d6;
}

.astrology-arrow.data-v-47582f5c {
    font-size: 40rpx;
    color: #c9c9d6;
    margin-left: 10rpx;
}
