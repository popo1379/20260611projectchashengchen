/* 每日抽签横向排列样式 */
.draw-section.data-v-47582f5c {
    margin-top: 80rpx;
    padding: 0 30rpx;
}

.draw-title.data-v-47582f5c {
    text-align: center;
    color: #666;
    font-size: 28rpx;
    font-weight: 500;
    margin-bottom: 20rpx;
}

.draw-row.data-v-47582f5c {
    display: flex;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    background-color: #fff;
    border-radius: 16rpx;
    padding: 24rpx 16rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.draw-item.data-v-47582f5c {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 10rpx 8rpx;
}

.draw-item.data-v-47582f5c:active {
    opacity: 0.6;
}

.draw-divider.data-v-47582f5c {
    width: 1rpx;
    height: 60rpx;
    background-color: #eee;
}

.draw-icon.data-v-47582f5c {
    font-size: 40rpx;
    margin-bottom: 10rpx;
}

.draw-name.data-v-47582f5c {
    color: #242122;
    font-size: 24rpx;
    font-weight: 500;
    text-align: center;
}

/* 功能未开放遮罩层 */
.lock-overlay.data-v-47582f5c {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 250, 246, 0.96);
    backdrop-filter: blur(8rpx);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
}

.lock-content.data-v-47582f5c {
