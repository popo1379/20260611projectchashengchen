.ui-click-hover {
    opacity: .6;
}

.ui-safe-area {
    height: constant(safe-area-inset-bottom);
    height: env(safe-area-inset-bottom);
}

.ui-title-bg {
    background-image: url(data:image/png;base64,);
    background-position: bottom;
    background-repeat: no-repeat;
    background-size: 100% auto;
}

.ui-skeleton {
    overflow: hidden;
    position: relative;
}

.ui-skeleton:before {
    animation: identifier .8s ease infinite;
    background: #fafbfd;
    box-shadow: 0 0 100rpx 150rpx #fafbfd;
    content: "";
    height: 300%;
    position: absolute;
    top: -30%;
    transform: rotate(20deg);
    width: 60%;
}

@-webkit-keyframes identifier {
    0% {
        left: -200%;
    }

    to {
        left: 200%;
    }
}

@keyframes identifier {
    0% {
        left: -200%;
    }

    to {
        left: 200%;
    }
}

.u-fade-zoom-enter,.u-fade-zoom-leave-to {
    transform: scale(.7)!important;
}

.ji {
    color: #bf242a!important;
}

.xion {
    color: #212121!important;
}

body,html {
    overscroll-behavior: none;
}

page {
    --main-colorA: "";
    --main-colorB: "";
    --font-color: "";
    background: linear-gradient(#fff,#f5f7fa 20rpx);
    font-family: Helvetica Neue,Helvetica,Verdana,sans-serif,Microsoft Yahei;
    height: 100%;
    letter-spacing: 2rpx;
    margin: auto;
    max-width: 750px;
    position: relative;
    width: 100%;
}

image {
    width: 100%;
}

image,img {
    -webkit-touch-callout: none;
    -webkit-user-drag: none;
    user-select: none;
}

text,view {
    font-family: Helvetica Neue,Helvetica,Verdana,sans-serif,Microsoft Yahei;
    letter-spacing: normal!important;
    user-select: none;
    word-break: break-all;
}

text {
    display: inline-block;
}

input,textarea {
    caret-color: #ff5e13;
}

input:focus,textarea:focus {
    outline: none;
}

input:-webkit-autofill,select:-webkit-autofill,textarea:-webkit-autofill {
    -webkit-text-fill-color: #000!important;
    -webkit-animation: 0;
    background-color: initial!important;
    background-image: none!important;
    -webkit-box-shadow: inset 0 0 0 1000px transparent!important;
    transition: background-color 50000s ease-in-out 0s!important;
}

.uni-sample-toast,uni-toast {
    z-index: 99999;
}

::-webkit-scrollbar {
    display: none;
}

@font-face {
    font-display:swap;font-family:BXZ-Bold;font-style:normal;font-weight:400;src:url(data:font/ttf;base64,);
}

page {
    --status-bar-height: 25px;
    --top-window-height: 0px;
    --window-top: 0px;
    --window-bottom: 0px;
    --window-left: 0px;
    --window-right: 0px;
    --window-magin: 0px;
}

[data-c-h="true"] {
    display: none!important;
}